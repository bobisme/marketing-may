{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Funnel Event Taxonomy",
  "type": "object",
  "required": ["north_star", "funnel", "events"],
  "properties": {
    "north_star": {"type": "string"},
    "qualified_intent_definition": {"type": "string"},
    "activation_event": {"type": "string"},
    "retention_signal": {"type": "string"},
    "funnel": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "metric", "definition"],
        "properties": {
          "stage": {"type": "string"},
          "metric": {"type": "string"},
          "definition": {"type": "string"},
          "owner": {"type": "string"},
          "target": {"type": "string"}
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event", "trigger", "properties", "why_it_matters"],
        "properties": {
          "event": {"type": "string"},
          "trigger": {"type": "string"},
          "properties": {"type": "array", "items": {"type": "string"}},
          "why_it_matters": {"type": "string"},
          "avoid": {"type": "string"}
        }
      }
    },
    "attribution_assumptions": {"type": "array", "items": {"type": "string"}}
  }
}
